NODE_ENV=development
PORT=3000
DATABASE_PATH=./data/mvp-chef-codex.sqlite
APP_NAME=MVP Chef Codex
# Optional colon-separated roots exposed by the server folder browser.
# PROJECT_BROWSER_ROOTS=/home/chef/Documents:/home/chef/Desktop:/home/chef/Downloads

# Wait 5 minutes before retrying a failed Codex prompt step.
CODEX_RETRY_DELAY_MS=300000
