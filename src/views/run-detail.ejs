<%- include('partials/layout') %>
<section class="container py-5" data-run-detail data-run-id="<%= run.id %>">
  <a href="/" class="btn btn-link ps-0">← Back to dashboard</a>
  <div class="recipe-page p-4 p-lg-5">
    <div class="d-flex flex-wrap align-items-start justify-content-between gap-3">
      <div>
        <p class="eyebrow">🔥 Cook session #<%= run.id %></p>
        <h1>Run Detail</h1>
        <p class="lead"><span data-run-recipe><%= run.recipe_name || 'Recipe run' %></span> for <span data-run-project><%= run.project_name || 'a project pantry' %></span>.</p>
        <% if (run.lock_owner) { %><p class="badge text-bg-warning">Locked by <%= run.lock_owner %> for run #<%= run.id %> until <%= run.lock_expires_at %></p><% } %>
      </div>
      <div class="run-actions btn-group" role="group" aria-label="Run controls">
        <form method="post" action="/runs/<%= run.id %>/pause"><button class="btn btn-warning" type="submit" data-run-pause>⏸️ Pause</button></form>
        <form method="post" action="/runs/<%= run.id %>/resume"><button class="btn btn-primary" type="submit" data-run-resume>▶️ Resume</button></form>
        <form method="post" action="/runs/<%= run.id %>/cancel"><button class="btn btn-danger" type="submit" data-run-cancel>🛑 Cancel</button></form>
        <form method="post" action="/runs/<%= run.id %>/rollback-last-step"><button class="btn btn-outline-danger" type="submit">↩️ Rollback last step</button></form>
      </div>
    </div>


    <% if (run.status === 'waiting_for_quota') { %>
      <div class="alert alert-warning" data-quota-status>
        <strong>Quota cooldown active.</strong>
        <span data-quota-message><%= run.error_message || 'Waiting for quota or rate-limit refill.' %></span>
        <div class="small mt-1">Next refill: <span data-quota-refill><%= run.quota_refill_at || 'Not set' %></span> · Retry <span data-quota-retry><%= run.quota_retry_count || 0 %></span></div>
        <form method="post" action="/runs/<%= run.id %>/quota-refill" class="row g-2 align-items-end mt-2">
          <div class="col-sm-8">
            <label class="form-label small fw-bold">Set next refill time manually</label>
            <input class="form-control" type="datetime-local" name="quotaRefillAt" required>
          </div>
          <div class="col-sm-4"><button class="btn btn-outline-dark w-100" type="submit">Save cooldown</button></div>
        </form>
      </div>
    <% } else { %>
      <div class="alert alert-warning d-none" data-quota-status>
        <strong>Quota cooldown active.</strong> <span data-quota-message></span>
        <div class="small mt-1">Next refill: <span data-quota-refill>Not set</span> · Retry <span data-quota-retry>0</span></div>
      </div>
    <% } %>

    <div class="row g-4 my-3">
      <div class="col-md-3"><div class="stat-card"><span>⏲️</span><strong><span class="status-badge" data-run-status><%= run.status %></span></strong><small>Status</small></div></div>
      <div class="col-md-3"><div class="stat-card"><span>🥄</span><strong data-run-current-step><%= runSnapshot && runSnapshot.currentStep ? runSnapshot.currentStep.title : 'Pending' %></strong><small>Current step</small></div></div>
      <div class="col-md-3"><div class="stat-card"><span>🔁</span><strong data-run-retries><%= runSnapshot ? runSnapshot.retryAttempts : 0 %></strong><small>Retry attempts</small></div></div>
      <div class="col-md-3"><div class="stat-card"><span>🌿</span><strong data-run-commit><%= run.commit_sha || 'Pending' %></strong><small>Commit</small></div></div>
    </div>

    <div class="paper-panel p-4 mb-4">
      <div class="d-flex justify-content-between gap-3 align-items-center mb-2">
        <h2 class="h4 m-0">Progress</h2>
        <strong data-run-progress-label><%= runSnapshot ? runSnapshot.progress : 0 %>%</strong>
      </div>
      <div class="chef-loader" data-run-progress role="progressbar" aria-label="Run progress: <%= runSnapshot ? runSnapshot.progress : 0 %>%" aria-valuemin="0" aria-valuemax="100" aria-valuenow="<%= runSnapshot ? runSnapshot.progress : 0 %>">
        <span class="chef-loader-orbit" aria-hidden="true">🥄</span>
        <span class="chef-loader-dish" aria-hidden="true">🍲</span>
        <span class="visually-hidden" data-run-progress-description><%= runSnapshot ? runSnapshot.progress : 0 %>% complete</span>
      </div>
      <p class="chef-loader-caption mb-0">Codex is cooking your recipe…</p>
    </div>

    <div class="paper-panel p-4 mb-4">
      <div class="d-flex flex-wrap justify-content-between gap-2 align-items-center mb-3">
        <h2 class="h4 m-0">Failure recovery tools</h2>
        <div class="btn-group btn-group-sm" role="group" aria-label="Failure recovery utilities">
          <a class="btn btn-outline-dark" href="/runs/<%= run.id %>/diff" target="_blank">Open diff viewer</a>
          <a class="btn btn-outline-dark" href="/runs/<%= run.id %>/logs" target="_blank">View logs</a>
          <a class="btn btn-outline-dark" href="/runs/<%= run.id %>/failure-report">Export failure report</a>
        </div>
      </div>
      <p class="text-muted small">Failed run state, edited prompts, skipped steps, and recovery actions are stored in SQLite so a run can be resumed after a server restart.</p>
    </div>

    <div class="paper-panel p-4 mb-4">
      <div class="d-flex justify-content-between align-items-center mb-2"><h2 class="h4 mb-0">Cooking steps</h2><span class="chef-badge badge-soft rounded-pill px-3 py-1">Live mise en place</span></div>
      <details class="prompt-list" open>
        <summary><span>Prompt list</span><span class="prompt-list-count" data-prompt-count><%= (run.steps || []).length %> prompts</span></summary>
      <div class="timeline mt-3" data-run-steps>
        <% (run.steps || []).forEach((step) => { %><div class="timeline-item" data-step-id="<%= step.id || step.step_order %>"><span><%= step.step_order %></span><div><strong><%= step.recipe_step_title || step.title || 'Recipe step' %></strong> <span class="status-badge"><%= step.status %></span><p><%= step.prompt || step.status %></p>
          <% if (['failed', 'paused', 'waiting_for_quota'].includes(step.status)) { %>
            <div class="failure-recovery-panel alert alert-danger mt-2">
              <strong>Failure recovery:</strong> <%= step.error_message || 'This step needs attention.' %>
              <div class="d-flex flex-wrap gap-2 mt-2">
                <form method="post" action="/runs/<%= run.id %>/steps/<%= step.id %>/retry"><button class="btn btn-sm btn-primary" type="submit">Retry failed step</button></form>
                <form method="post" action="/runs/<%= run.id %>/steps/<%= step.id %>/skip"><button class="btn btn-sm btn-outline-secondary" type="submit">Skip failed step</button></form>
                <form method="post" action="/runs/<%= run.id %>/steps/<%= step.id %>/continue-from"><button class="btn btn-sm btn-outline-primary" type="submit">Continue from this step</button></form>
                <a class="btn btn-sm btn-outline-dark" href="/runs/<%= run.id %>/diff?stepId=<%= step.id %>" target="_blank">Diff</a>
                <a class="btn btn-sm btn-outline-dark" href="/runs/<%= run.id %>/logs?stepId=<%= step.id %>" target="_blank">Logs</a>
              </div>
              <form method="post" action="/runs/<%= run.id %>/steps/<%= step.id %>/edit-retry" class="mt-2">
                <label class="form-label small fw-bold">Edit failed prompt and retry</label>
                <textarea class="form-control form-control-sm" name="prompt" rows="3"><%= step.prompt_override || step.prompt || '' %></textarea>
                <button class="btn btn-sm btn-primary mt-1" type="submit">Retry with edited prompt</button>
              </form>
            </div>
          <% } %>
          <% if (step.status === 'waiting_for_approval') { %>
            <div class="approval-panel alert alert-info mt-2">
              <strong>Human approval required:</strong> <%= step.error_message || 'Review this checkpoint.' %>
              <div class="d-flex flex-wrap gap-2 mt-2">
                <form method="post" action="/runs/<%= run.id %>/steps/<%= step.id %>/approve"><input type="hidden" name="approvalPoint" value="<%= step.approval_point || '' %>"><button class="btn btn-sm btn-success" type="submit">Approve</button></form>
                <form method="post" action="/runs/<%= run.id %>/steps/<%= step.id %>/reject"><input class="form-control form-control-sm" name="reason" placeholder="Reject reason"><button class="btn btn-sm btn-outline-danger mt-1" type="submit">Reject</button></form>
                <form method="post" action="/runs/<%= run.id %>/steps/<%= step.id %>/skip"><button class="btn btn-sm btn-outline-secondary" type="submit">Skip step</button></form>
                <form method="post" action="/runs/<%= run.id %>/cancel"><button class="btn btn-sm btn-danger" type="submit">Cancel run</button></form>
              </div>
              <form method="post" action="/runs/<%= run.id %>/steps/<%= step.id %>/edit-retry" class="mt-2">
                <label class="form-label small fw-bold">Edit prompt and retry</label>
                <textarea class="form-control form-control-sm" name="prompt" rows="3"><%= step.prompt_override || step.prompt || '' %></textarea>
                <button class="btn btn-sm btn-primary mt-1" type="submit">Retry with edited prompt</button>
              </form>
            </div>
          <% } %>
        </div></div><% }) %>
        <% if (!run.steps || !run.steps.length) { %><div class="timeline-item"><span>1</span><div><strong>Preheat Codex</strong><p>This demo run is pending and ready for recipe steps.</p></div></div><% } %>
      </div>
      </details>
    </div>

    <div class="paper-panel p-4">
      <div class="terminal-toolbar">
        <div class="d-flex align-items-center gap-2"><span class="terminal-dots"><span></span><span></span><span></span></span><h2 class="h5 m-0">Live terminal logs</h2></div>
        <span class="status-badge" data-run-connection>Connecting</span>
      </div>
      <div class="terminal-panel" data-run-terminal aria-live="polite">
        <pre><code data-run-logs><%= runSnapshot ? `${runSnapshot.stdout}${runSnapshot.stderr ? `\n${runSnapshot.stderr}` : ''}` : 'Waiting for logs…' %></code></pre>
      </div>
    </div>
  </div>
</section>
<%- include('partials/footer') %>
