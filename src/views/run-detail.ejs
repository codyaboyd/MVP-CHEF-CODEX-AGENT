<%- include('partials/layout') %>
<section class="container py-5">
  <a href="/" class="btn btn-link ps-0">← Back to dashboard</a>
  <div class="recipe-page p-4 p-lg-5">
    <p class="eyebrow">🔥 Cook session #<%= run.id %></p>
    <h1>Run Detail</h1>
    <p class="lead"><%= run.recipe_name || 'Recipe run' %> for <%= run.project_name || 'a project pantry' %>.</p>
    <div class="row g-4 my-3">
      <div class="col-md-4"><div class="stat-card"><span>⏲️</span><strong><%= run.status %></strong><small>Status</small></div></div>
      <div class="col-md-4"><div class="stat-card"><span>🌿</span><strong><%= run.commit_sha || 'Pending' %></strong><small>Commit</small></div></div>
      <div class="col-md-4"><div class="stat-card"><span>🥧</span><strong><%= run.pr_url ? 'Plated' : 'Not plated' %></strong><small>Pull request</small></div></div>
    </div>
    <div class="paper-panel p-4">
      <h2 class="h4">Cooking steps</h2>
      <div class="timeline">
        <% (run.steps || []).forEach((step) => { %><div class="timeline-item"><span><%= step.step_order %></span><div><strong><%= step.recipe_step_title || step.title || 'Recipe step' %></strong><p><%= step.prompt || step.status %></p></div></div><% }) %>
        <% if (!run.steps || !run.steps.length) { %><div class="timeline-item"><span>1</span><div><strong>Preheat Codex</strong><p>This demo run is pending and ready for recipe steps.</p></div></div><% } %>
      </div>
    </div>
  </div>
</section>
<%- include('partials/footer') %>
