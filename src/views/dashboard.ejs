<%- include('partials/layout') %>
<section class="codex-home container py-5">
  <div class="codex-intro text-center mx-auto">
    <span class="codex-mark" aria-hidden="true">⌁</span>
    <h1>What do you want to build?</h1>
    <p>Choose a folder, describe the work, and let Codex apply it. Add more prompts when the work needs multiple steps.</p>
  </div>

  <form method="post" action="/run" class="prompt-composer mx-auto" data-quick-run-form>
    <% if (composerErrors.length) { %>
      <div class="alert alert-danger mb-3" role="alert">
        <% composerErrors.forEach((error) => { %><div><%= error %></div><% }) %>
      </div>
    <% } %>

    <div class="folder-picker-row">
      <span aria-hidden="true">📁</span>
      <input class="folder-path-input" name="folderPath" value="<%= composer.folderPath %>" placeholder="Select a folder or paste its absolute path" required data-project-path>
      <button class="btn btn-light btn-sm" type="button" data-folder-browser-button>Browse folders</button>
    </div>
    <select class="form-select form-select-sm folder-browser" aria-label="Server project folders" hidden data-folder-browser></select>
    <p class="folder-hint" data-quick-folder-status>Codex works directly in this folder. Git is optional.</p>

    <div class="prompt-chain" data-prompt-chain>
      <% composer.prompts.forEach((prompt, index) => { %>
        <div class="prompt-chain-item" data-prompt-chain-item>
          <span class="prompt-index"><%= index + 1 %></span>
          <textarea name="prompts" rows="3" placeholder="Ask Codex to build, fix, explain, or automate something…" required><%= prompt %></textarea>
          <button class="prompt-remove" type="button" aria-label="Remove prompt" data-remove-prompt>×</button>
        </div>
      <% }) %>
    </div>

    <div class="composer-actions">
      <button class="btn btn-link" type="button" data-add-prompt>＋ Add another prompt</button>
      <button class="btn btn-dark rounded-pill px-4" type="submit">Run with Codex <span aria-hidden="true">↑</span></button>
    </div>
  </form>

  <div class="quick-notes mx-auto">
    <span>⌘ Runs locally</span><span>↳ Prompts run in order</span><span>◌ Review every change</span>
  </div>

  <% if (runs && runs.length) { %>
    <section class="recent-work mx-auto mt-5">
      <div class="d-flex justify-content-between align-items-center mb-3"><h2>Recent runs</h2><a href="/recipes">Saved workflows</a></div>
      <% runs.slice(0, 4).forEach((run) => { %>
        <a class="recent-run" href="/runs/<%= run.id %>"><span><strong><%= run.recipe_name %></strong><small><%= run.project_name %></small></span><span class="status-badge" data-status="<%= run.status %>"><%= run.status %></span></a>
      <% }) %>
    </section>
  <% } %>
</section>
<%- include('partials/footer') %>
