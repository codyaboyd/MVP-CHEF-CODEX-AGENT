<%- include('partials/layout') %>
<section class="hero py-5">
  <div class="container">
    <div class="row align-items-center g-4">
      <div class="col-lg-7">
        <p class="badge rounded-pill text-bg-warning mb-3">🍞 Fresh from the Codex kitchen</p>
        <h1 class="display-4 fw-black">Cook up your next MVP, one recipe card at a time.</h1>
        <p class="lead">Track projects, reusable prompt recipes, and Codex runs in a playful digital cookbook.</p>
        <div class="d-flex flex-wrap gap-2">
          <a class="btn btn-primary btn-lg rounded-pill chef-button" href="/recipes/new">Write a new recipe</a>
          <a class="btn btn-outline-dark btn-lg rounded-pill chef-button" href="/recipes">Open cookbook</a>
        </div>
      </div>
      <div class="col-lg-5">
        <div class="oven-timer mx-auto text-center">
          <div class="timer-face"><span><%= stats.progress %>%</span></div>
          <h2 class="h4 mt-3">Cooking progress</h2>
          <p class="mb-0 text-muted">Oven timer for launch readiness.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="container py-5">
  <div class="row g-4 mb-5">
    <div class="col-md-4"><div class="stat-card"><span>📁</span><strong><%= stats.projects %></strong><small>Projects simmering</small></div></div>
    <div class="col-md-4"><div class="stat-card"><span>🗂️</span><strong><%= stats.recipes %></strong><small>Recipe cards</small></div></div>
    <div class="col-md-4"><div class="stat-card"><span>🔥</span><strong><%= stats.runs %></strong><small>Cook sessions</small></div></div>
  </div>

  <div class="row g-4">
    <div class="col-lg-8">
      <div class="section-heading"><h2>Today's recipe cards</h2><a href="/recipes">View all</a></div>
      <div class="row g-4">
        <% recipes.slice(0, 3).forEach((recipe) => { %>
          <div class="col-md-6">
            <article class="card recipe-card h-100 border-0">
              <div class="card-body p-4">
                <span class="badge rounded-pill phase-badge mb-3"><%= recipe.phase %></span>
                <h3 class="h4"><%= recipe.title %></h3>
                <p class="text-muted"><%= recipe.summary %></p>
                <a class="stretched-link fw-bold" href="/recipes/<%= recipe.id %>">Open recipe →</a>
              </div>
            </article>
          </div>
        <% }) %>
      </div>
    </div>
    <div class="col-lg-4">
      <div class="paper-panel p-4 h-100">
        <h2 class="h4">Chef's prep list</h2>
        <ul class="prep-list">
          <li>Pick a project pantry.</li>
          <li>Choose a reusable recipe.</li>
          <li>Watch the oven timer.</li>
          <li>Plate the PR when golden.</li>
        </ul>
      </div>
    </div>
  </div>
</section>
<%- include('partials/footer') %>
