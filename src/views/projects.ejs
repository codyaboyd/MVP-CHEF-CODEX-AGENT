<%- include('partials/layout') %>
<section class="container py-5">
  <div class="cookbook-title mb-4"><div><p class="eyebrow">📁 Project pantry</p><h1>Projects</h1><p class="text-muted">Every pantry holds repos, recipes, and launch ingredients.</p></div></div>
  <div class="row g-4">
    <% projects.forEach((project) => { %>
      <div class="col-lg-6">
        <article class="paper-panel p-4 h-100">
          <div class="d-flex justify-content-between gap-3">
            <div><h2 class="h4"><%= project.name %></h2><p class="text-muted"><%= project.description %></p></div>
            <div class="project-badge">🍱</div>
          </div>
          <div class="pantry-row"><span>Repo path</span><code><%= project.repo_path %></code></div>
          <% if (project.github_repo_url) { %><div class="pantry-row"><span>Remote</span><a href="<%= project.github_repo_url %>"><%= project.github_repo_url %></a></div><% } %>
          <div class="progress mt-4 oven-progress" role="progressbar" aria-label="Project cooking progress" aria-valuenow="72" aria-valuemin="0" aria-valuemax="100"><div class="progress-bar" style="width: 72%">72% baked</div></div>
          <p class="small mt-3 mb-0"><strong><%= project.recipe_count %></strong> recipe cards stocked.</p>
        </article>
      </div>
    <% }) %>
  </div>
</section>
<%- include('partials/footer') %>
