<%- include('partials/layout') %>
<%
  const values = settings.reduce((all, setting) => ({ ...all, [setting.key]: setting.value }), {});
  const valueFor = (key, fallback = '') => values[key] ?? fallback;
  const sensitiveKeys = new Set(['codexApiKey']);
  const displayValue = (setting) => sensitiveKeys.has(setting.key) && setting.value ? '••••••••' : setting.value;
  const boolSelect = (key, label, help) => { %>
    <div class="col-md-6">
      <label class="form-label fw-bold" for="<%= key %>"><%= label %></label>
      <select class="form-select" id="<%= key %>" name="<%= key %>">
        <option value="true" <%= valueFor(key, 'false') === 'true' ? 'selected' : '' %>>Enabled</option>
        <option value="false" <%= valueFor(key, 'false') !== 'true' ? 'selected' : '' %>>Disabled</option>
      </select>
      <% if (help) { %><div class="form-text"><%= help %></div><% } %>
    </div>
  <% };
%>
<section class="container py-5 settings-page">
  <div class="row g-4 align-items-start mb-4">
    <div class="col-lg-5">
      <div class="paper-panel p-4 h-100">
        <p class="eyebrow">⚙️ Kitchen controls</p>
        <h1 class="fw-black">Settings</h1>
        <p class="text-muted">Tune Codex execution, safety rails, quota recovery, and the workbench display from one pantry.</p>
        <div class="display-1">🧂</div>
      </div>
    </div>
    <div class="col-lg-7">
      <div class="paper-panel p-4 h-100">
        <h2 class="h4 fw-black">Control center</h2>
        <p class="mb-0 text-muted">Changes are saved as application defaults and used by future runs unless a run or project overrides them.</p>
        <div class="settings-summary mt-3">
          <span>Codex: <strong><%= valueFor('codexCommandPath', 'codex') %></strong></span>
          <span>Cooldown: <strong><%= valueFor('defaultCooldownMinutes', '60') %> min</strong></span>
          <span>Parallel runs: <strong><%= valueFor('maxParallelRuns', '1') %></strong></span>
        </div>
      </div>
    </div>
  </div>

  <form method="post" action="/settings" class="settings-form">
    <div class="row g-4">
      <div class="col-lg-6">
        <section class="paper-panel p-4 settings-section">
          <p class="eyebrow">🤖 Codex CLI settings</p>
          <h2 class="h4 fw-black">Runner command and auth</h2>
          <div class="row g-3">
            <div class="col-12">
              <label class="form-label fw-bold" for="codexCommandPath">Codex command path</label>
              <input class="form-control" id="codexCommandPath" name="codexCommandPath" value="<%= valueFor('codexCommandPath', 'codex') %>" placeholder="codex or /usr/local/bin/codex">
              <div class="form-text">Command or absolute path used to launch the Codex CLI. Setup validation scans common locations such as <code>/snap/bin/codex</code> and saves a discovered path when <code>codex</code> is not on this service's PATH.</div>
            </div>
            <div class="col-md-6">
              <label class="form-label fw-bold" for="codexAuthMode">Codex auth mode</label>
              <select class="form-select" id="codexAuthMode" name="codexAuthMode">
                <% [['environment','CLI login / environment'], ['config_dir','Config directory'], ['api_key','Legacy API key setting']].forEach(([value, label]) => { %>
                  <option value="<%= value %>" <%= valueFor('codexAuthMode', 'environment') === value ? 'selected' : '' %>><%= label %></option>
                <% }) %>
              </select>
              <div class="form-text">Most installs should use the existing Codex CLI login or environment. An API key is not required when <code>codex</code> is already authenticated.</div>
            </div>
            <div class="col-md-6">
              <label class="form-label fw-bold" for="codexApiKey">Codex / OpenAI API key (legacy optional)</label>
              <input class="form-control" id="codexApiKey" name="codexApiKey" type="password" value="<%= valueFor('codexApiKey', '') %>" autocomplete="off" placeholder="Leave blank for CLI login">
              <div class="form-text">Only use this for unusual deployments that cannot rely on <code>codex login</code>, a config directory, or environment-managed credentials.</div>
            </div>
            <div class="col-md-6">
              <label class="form-label fw-bold" for="codexConfigDir">Codex config directory</label>
              <input class="form-control" id="codexConfigDir" name="codexConfigDir" value="<%= valueFor('codexConfigDir', '') %>" placeholder="/home/app/.codex">
            </div>
            <div class="col-md-6">
              <label class="form-label fw-bold" for="codexModel">Default Codex model</label>
              <input class="form-control" id="codexModel" name="codexModel" value="<%= valueFor('codexModel', '') %>" placeholder="Use CLI default">
              <div class="form-text">Leave blank to use the Codex CLI default. If your account does not support that model, enter one available to your Codex login; recipe runs pass it to <code>codex exec --model</code>.</div>
            </div>
            <div class="col-md-6">
              <label class="form-label fw-bold" for="codexApprovalPolicy">Codex approval policy</label>
              <select class="form-select" id="codexApprovalPolicy" name="codexApprovalPolicy">
                <% [['suggest','Suggest (ask before risky actions)'], ['on-request','On request (agent may ask)'], ['never','Never ask during runs']].forEach(([value, label]) => { %>
                  <option value="<%= value %>" <%= valueFor('codexApprovalPolicy', 'suggest') === value ? 'selected' : '' %>><%= label %></option>
                <% }) %>
              </select>
              <div class="form-text">Controls when Codex may pause for operator permission. Use <strong>Suggest</strong> for the safest default; use <strong>Never</strong> only for fully unattended runs.</div>
            </div>
            <div class="col-md-6">
              <label class="form-label fw-bold" for="codexSandboxMode">Codex sandbox mode</label>
              <select class="form-select" id="codexSandboxMode" name="codexSandboxMode">
                <% [['workspace-write','Workspace write (recommended)'], ['read-only','Read only'], ['danger-full-access','Full access (advanced)']].forEach(([value, label]) => { %>
                  <option value="<%= value %>" <%= valueFor('codexSandboxMode', 'workspace-write') === value ? 'selected' : '' %>><%= label %></option>
                <% }) %>
              </select>
              <div class="form-text">Limits what Codex can access while running. <strong>Workspace write</strong> lets it edit the project; <strong>Read only</strong> is for inspection; <strong>Full access</strong> removes filesystem limits.</div>
            </div>
          </div>
        </section>
      </div>

      <div class="col-lg-6">
        <section class="paper-panel p-4 settings-section">
          <p class="eyebrow">🛡️ Safety settings</p>
          <h2 class="h4 fw-black">Approval gates</h2>
          <div class="row g-3">
            <% boolSelect('projectSafeModeDefault', 'Default project safe mode', 'Start new projects with stricter prompt linting enabled.'); %>
            <% boolSelect('secretScannerAllowOverride', 'Allow secrets scanner manual override', 'Permit explicit operator override of secret-scan blocks.'); %>
          </div>
        </section>
      </div>

      <div class="col-lg-6">
        <section class="paper-panel p-4 settings-section">
          <p class="eyebrow">⏲️ Quota/cooldown settings</p>
          <h2 class="h4 fw-black">Quota recovery</h2>
          <div class="row g-3">
            <div class="col-md-6">
              <label class="form-label fw-bold" for="defaultCooldownMinutes">Default cooldown minutes</label>
              <input class="form-control" id="defaultCooldownMinutes" type="number" min="0" name="defaultCooldownMinutes" value="<%= valueFor('defaultCooldownMinutes', '60') %>">
            </div>
            <% boolSelect('autoResumeAfterCooldown', 'Auto resume', 'Resume waiting runs automatically after a quota cooldown.'); %>
          </div>
        </section>
      </div>

      <div class="col-lg-6">
        <section class="paper-panel p-4 settings-section">
          <p class="eyebrow">🎨 UI preferences</p>
          <h2 class="h4 fw-black">Workbench display</h2>
          <div class="row g-3">
            <% boolSelect('compactUiMode', 'Compact UI mode', 'Use denser cards and lists on operational pages.'); %>
            <% boolSelect('showAdvancedSettings', 'Show advanced settings', 'Keep lower-level runner controls visible by default.'); %>
          </div>
        </section>
      </div>

      <div class="col-lg-6">
        <section class="paper-panel p-4 settings-section">
          <p class="eyebrow">🏃 Runner limits</p>
          <h2 class="h4 fw-black">Concurrency and timeouts</h2>
          <div class="row g-3">
            <div class="col-md-6">
              <label class="form-label fw-bold" for="maxParallelRuns">Max parallel runs</label>
              <input class="form-control" id="maxParallelRuns" type="number" min="1" name="maxParallelRuns" value="<%= valueFor('maxParallelRuns', '1') %>">
            </div>
            <div class="col-md-6">
              <label class="form-label fw-bold" for="maxStepRuntimeMinutes">Max step runtime</label>
              <input class="form-control" id="maxStepRuntimeMinutes" type="number" min="1" name="maxStepRuntimeMinutes" value="<%= valueFor('maxStepRuntimeMinutes', '30') %>">
              <div class="form-text">Minutes before a Codex step is considered timed out.</div>
            </div>
          </div>
        </section>
      </div>
    </div>

    <div class="paper-panel p-4 mt-4 d-flex flex-wrap gap-3 align-items-center justify-content-between">
      <div>
        <h2 class="h5 fw-black mb-1">Save the pantry labels</h2>
        <p class="text-muted mb-0">Persist these defaults for the next batch of Codex recipes.</p>
      </div>
      <button class="btn btn-primary btn-lg rounded-pill" type="submit">Save settings</button>
    </div>
  </form>

  <% if (setupValidation) { %>
    <section class="paper-panel p-4 mt-4">
      <h2 class="h4 fw-black">Setup validation</h2>
      <p class="text-muted">These readiness checks verify whether Codex is ready before runs depend on it.</p>
      <div class="row g-3">
        <% [['Codex', setupValidation.codex]].forEach(([groupName, group]) => { %>
          <div class="col-lg-6">
            <div class="list-group list-group-flush settings-list">
              <div class="list-group-item"><strong><%= groupName %></strong><span><%= group.ok ? '✅ Ready' : '🛠️ Needs attention' %></span></div>
              <% group.checks.forEach((check) => { %>
                <div class="list-group-item">
                  <strong><%= check.ok ? '✅' : (check.skipped ? '➖' : '❌') %> <%= check.label %></strong>
                  <span><%= check.detail %></span>
                </div>
              <% }) %>
            </div>
          </div>
        <% }) %>
      </div>
    </section>
  <% } %>

  <section class="paper-panel p-4 mt-4">
    <h2 class="h4 fw-black">Current raw settings</h2>
    <div class="list-group list-group-flush settings-list">
      <% settings.forEach((setting) => { %>
        <div class="list-group-item"><strong><%= setting.key %></strong><span><%= displayValue(setting) %></span></div>
      <% }) %>
    </div>
  </section>
</section>
<%- include('partials/footer') %>
