<%- include('partials/layout') %>
<section class="container py-5">
  <div class="row g-4 align-items-start">
    <div class="col-lg-5"><div class="paper-panel p-4"><p class="eyebrow">⚙️ Kitchen controls</p><h1>Settings</h1><p class="text-muted">Tune your cookbook defaults, pantry labels, and oven notifications.</p><div class="display-1">🧂</div></div></div>
    <div class="col-lg-7"><div class="paper-panel p-4"><h2 class="h4">App settings</h2>
      <form method="post" action="/settings" class="settings-form">
        <% const values = settings.reduce((all, setting) => ({ ...all, [setting.key]: setting.value }), {}); %>
        <div class="row g-3">
          <div class="col-md-6"><label class="form-label">Default cooldown minutes</label><input class="form-control" type="number" min="0" name="defaultCooldownMinutes" value="<%= values.defaultCooldownMinutes || '60' %>"></div>
          <div class="col-md-6"><label class="form-label">Max retries after quota</label><input class="form-control" type="number" min="0" name="maxRetriesAfterQuota" value="<%= values.maxRetriesAfterQuota || '3' %>"></div>
          <% [['autoResumeAfterCooldown','Auto-resume after cooldown'], ['autoMergeEnabled','Auto-merge enabled'], ['requireHumanApprovalBeforeMerge','Require approval before merge'], ['protectedMainMode','Protected main mode']].forEach(([key, label]) => { %>
            <div class="col-md-6"><label class="form-label"><%= label %></label><select class="form-select" name="<%= key %>"><option value="true" <%= values[key] !== 'false' ? 'selected' : '' %>>Enabled</option><option value="false" <%= values[key] === 'false' ? 'selected' : '' %>>Disabled</option></select></div>
          <% }) %>
        </div>
        <button class="btn btn-primary mt-3" type="submit">Save settings</button>
      </form>
      <hr><div class="list-group list-group-flush settings-list">
        <% settings.forEach((setting) => { %><div class="list-group-item"><strong><%= setting.key %></strong><span><%= setting.value %></span></div><% }) %>
      </div>
    </div></div>
  </div>
</section>
<%- include('partials/footer') %>
