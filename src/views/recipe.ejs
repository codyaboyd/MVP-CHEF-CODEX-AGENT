<%- include('partials/layout') %>
<section class="container py-5">
  <a href="/" class="btn btn-link ps-0">← Back to cookbook</a>
  <div class="recipe-page p-4 p-lg-5 shadow-sm">
    <span class="badge rounded-pill phase-badge mb-3"><%= recipe.phase %></span>
    <h1 class="display-5 fw-bold"><%= recipe.title %></h1>
    <p class="lead"><%= recipe.summary %></p>
    <div class="row g-4 mt-3">
      <div class="col-lg-5">
        <div class="paper-panel h-100">
          <h2 class="h4">Ingredients</h2>
          <ul class="ingredient-list">
            <% recipe.ingredientsList.forEach((ingredient) => { %>
              <li><%= ingredient %></li>
            <% }) %>
          </ul>
        </div>
      </div>
      <div class="col-lg-7">
        <div class="paper-panel h-100">
          <h2 class="h4">Instructions</h2>
          <ol class="instruction-list">
            <% recipe.instructionSteps.forEach((step) => { %>
              <li><%= step %></li>
            <% }) %>
          </ol>
        </div>
      </div>
    </div>
  </div>
</section>
<%- include('partials/footer') %>
