<div class="chef-mascot" data-chef-mascot data-mood="idle" aria-live="polite" aria-label="Animated MVP Chef mascot">
  <button class="chef-mascot-hat" type="button" data-chef-hat aria-label="Chef hat easter egg" title="Chef mode"><span></span><span></span><span></span></button>
  <div class="chef-mascot-face" aria-hidden="true">
    <span class="chef-eye chef-eye-left"></span><span class="chef-eye chef-eye-right"></span>
    <span class="chef-mouth"></span>
  </div>
  <div class="chef-mascot-arm chef-arm-left">👋</div>
  <div class="chef-mascot-arm chef-arm-right">🥄</div>
  <div class="chef-mascot-pot" aria-hidden="true"><span class="pot-bubble"></span><span class="pot-bubble"></span><span class="pot-bubble"></span>🍲</div>
  <div class="chef-mascot-bubble" data-chef-message>Need a recipe?</div>
</div>
